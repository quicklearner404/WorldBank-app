<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_transfer_success.xml
    Owner  : Dev 2
    Mockup : Page 12
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_bg">

    <!-- ── TOP BAR ── -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="@dimen/screen_horizontal_padding"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/ibBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_chevron_left"
            android:contentDescription="@string/cd_back_button"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <TextView
            android:id="@+id/tvScreenTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_transfer_success"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ── RECEIPT CARD ── -->
    <androidx.cardview.widget.CardView
        android:id="@+id/receiptCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/screen_horizontal_padding"
        android:layout_marginTop="8dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingBottom="24dp"
            android:paddingTop="8dp"
            android:gravity="center_horizontal">

            <!-- Success circle checkmark -->
            <FrameLayout
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_marginTop="8dp">

                <View
                    android:id="@+id/ivSuccessCircle"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:background="@drawable/shape_success_circle" />

                <ImageView
                    android:id="@+id/ivCheckmark"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/checkbox_on_background"
                    android:tint="@color/purple_primary"
                    android:contentDescription="@null" />
            </FrameLayout>

            <!-- "Total" label -->
            <TextView
                android:id="@+id/tvTotalLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_total"
                android:textColor="@color/gray_text"
                android:textSize="14sp"
                android:layout_marginTop="12dp" />

            <!-- Total amount -->
            <TextView
                android:id="@+id/tvTotalAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/black"
                android:textSize="32sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp"
                tools:text="$901.00" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/gray_divider"
                android:layout_marginTop="20dp" />

            <!-- Transfer details heading -->
            <TextView
                android:id="@+id/tvTransferDetailsLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_transfer_details"
                android:textColor="@color/black"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp" />

            <!-- Total transfer row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <TextView
                    android:id="@+id/tvTotalTransferLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/label_total_transfer"
                    android:textColor="@color/gray_text"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvTotalTransferAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/black"
                    android:textSize="13sp"
                    tools:text="$900.00" />
            </LinearLayout>

            <!-- Admin fee row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">

                <TextView
                    android:id="@+id/tvAdminFeeLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/label_admin_fee"
                    android:textColor="@color/gray_text"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvAdminFeeAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/black"
                    android:textSize="13sp"
                    tools:text="$1.00" />
            </LinearLayout>

            <!-- Total (green) row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">

                <TextView
                    android:id="@+id/tvTotalLabel2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/label_total"
                    android:textColor="@color/gray_text"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvTotalAmountGreen"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/green_credit"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    tools:text="$901.00" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/gray_divider"
                android:layout_marginTop="16dp" />

            <!-- Immediate note -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_note_box"
                android:padding="12dp">

                <ImageView
                    android:id="@+id/ivClockIcon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_menu_recent_history"
                    android:tint="@color/gray_text"
                    android:contentDescription="@null" />

                <TextView
                    android:id="@+id/tvImmediateNote"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:text="@string/transfer_immediate_note"
                    android:textColor="@color/gray_text"
                    android:textSize="12sp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ── SHARE + DONE BUTTONS ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginHorizontal="@dimen/screen_horizontal_padding"
        android:layout_marginBottom="24dp"
        android:weightSum="2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Share -->
        <Button
            android:id="@+id/btnShare"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="@string/btn_share"
            android:textColor="@color/black"
            android:textSize="@dimen/text_button"
            android:background="@drawable/bg_white_button"
            android:stateListAnimator="@null" />

        <!-- Done -->
        <Button
            android:id="@+id/btnDone"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="@string/btn_done"
            android:textColor="@color/white"
            android:textSize="@dimen/text_button"
            android:textStyle="bold"
            android:background="@drawable/bg_purple_button"
            android:stateListAnimator="@null" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
