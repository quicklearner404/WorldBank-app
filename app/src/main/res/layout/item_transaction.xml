<?xml version="1.0" encoding="utf-8"?>
<!--
    item_transaction.xml
    Owner : Dev 2
    Used in: HomeActivity (rvTransactions) and TransactionHistoryActivity
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="10dp">

    <!-- Icon / Avatar background box -->
    <FrameLayout
        android:id="@+id/flTransactionIcon"
        android:layout_width="@dimen/transaction_icon_size"
        android:layout_height="@dimen/transaction_icon_size"
        android:background="@drawable/bg_transaction_icon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Initials text (shown when no image) -->
        <TextView
            android:id="@+id/tvTransactionInitials"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:textColor="@color/purple_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            tools:text="LP" />

        <!-- Category icon (shown for non-person transactions) -->
        <ImageView
            android:id="@+id/ivTransactionIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:visibility="gone"
            android:contentDescription="@null"
            tools:src="@android:drawable/ic_menu_agenda" />

    </FrameLayout>

    <!-- Transaction name -->
    <TextView
        android:id="@+id/tvTransactionName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:textColor="@color/black"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@id/flTransactionIcon"
        app:layout_constraintEnd_toStartOf="@id/tvTransactionAmount"
        app:layout_constraintTop_toTopOf="@id/flTransactionIcon"
        tools:text="Transfer To Ahmad F" />

    <!-- Date and time -->
    <TextView
        android:id="@+id/tvTransactionDate"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="4dp"
        android:textColor="@color/gray_text"
        android:textSize="12sp"
        app:layout_constraintStart_toEndOf="@id/flTransactionIcon"
        app:layout_constraintEnd_toStartOf="@id/tvTransactionAmount"
        app:layout_constraintTop_toBottomOf="@id/tvTransactionName"
        tools:text="6 Sep, 2024  •  17:02" />

    <!-- Amount (red for debit, green for credit) -->
    <TextView
        android:id="@+id/tvTransactionAmount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/flTransactionIcon"
        app:layout_constraintBottom_toBottomOf="@id/flTransactionIcon"
        tools:text="-$163.98"
        tools:textColor="@color/red_debit" />

</androidx.constraintlayout.widget.ConstraintLayout>
