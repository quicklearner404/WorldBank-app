<?xml version="1.0" encoding="utf-8"?>
<!--
    item_card_small.xml
    Used in CardStatisticActivity rvCards horizontal carousel
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="280dp"
    android:layout_height="80dp"
    android:layout_marginEnd="12dp"
    app:cardBackgroundColor="@color/purple_primary"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_card_purple"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp">

        <!-- Card nickname e.g. "Virtual Kuroo Master Card" -->
        <TextView
            android:id="@+id/tvSmallCardName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/ivSmallCardLogo"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Virtual Kuroo Master Card" />

        <!-- Mastercard / Visa logo -->
        <ImageView
            android:id="@+id/ivSmallCardLogo"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_mastercard"
            android:contentDescription="@null"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Masked number e.g. "**** 9809" -->
        <TextView
            android:id="@+id/tvSmallCardNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#CCFFFFFF"
            android:textSize="12sp"
            android:layout_marginTop="2dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvSmallCardName"
            tools:text="**** 9809" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>
