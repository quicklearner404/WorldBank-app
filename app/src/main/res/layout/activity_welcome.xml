<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/gray_bg"
    android:paddingLeft="@dimen/section_spacing"
    android:paddingRight="@dimen/section_spacing"
    android:paddingBottom="48dp">

    <!-- logo and name centered in the middle of the screen -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">

        <ImageView
            android:id="@+id/iv_logo"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_logo"
            android:contentDescription="@null"
            android:layout_gravity="center_horizontal" />

        <TextView
            android:id="@+id/tv_app_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/item_spacing"
            android:text="@string/app_name"
            android:textColor="@color/purple_primary"
            android:textSize="@dimen/text_heading_large"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:text="Banking made simple"
            android:textColor="@color/gray_hint"
            android:textSize="@dimen/text_body" />

    </LinearLayout>

    <!-- buttons pinned to the bottom -->
    <Button
        android:id="@+id/btn_login"
        style="@style/Widget.WorldBank.Button.Primary"
        android:text="@string/btn_log_in" />

    <Button
        android:id="@+id/btn_signup"
        style="@style/Widget.WorldBank.Button.Secondary"
        android:text="@string/btn_sign_up"
        android:layout_marginTop="@dimen/item_spacing" />

</LinearLayout>