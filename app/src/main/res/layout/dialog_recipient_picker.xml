<?xml version="1.0" encoding="utf-8"?>
<!--
    dialog_recipient_picker.xml — UPGRADED SLEEK DESIGN
    Used in SendMoneyActivity to pick a recipient.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_white_card"
    android:paddingHorizontal="24dp"
    android:paddingTop="24dp"
    android:paddingBottom="32dp">

    <!-- Title Bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Recipient"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <ImageButton
            android:id="@+id/btnCloseDialog"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="@color/gray_text"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Recent Contacts Section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Saved Contacts"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:textSize="14sp"
        android:layout_marginBottom="12dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvContacts"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

    <!-- Manual entry -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enter Account Manually"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:textSize="14sp"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/etRecipientAccount"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/bg_input_field"
        android:hint="Account Number / IBAN"
        android:textColorHint="@color/gray_hint"
        android:textColor="@color/black"
        android:textSize="14sp"
        android:paddingHorizontal="16dp"
        android:inputType="text"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/etRecipientName"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/bg_input_field"
        android:hint="Recipient Name"
        android:textColorHint="@color/gray_hint"
        android:textColor="@color/black"
        android:textSize="14sp"
        android:paddingHorizontal="16dp"
        android:inputType="textPersonName"
        android:layout_marginBottom="24dp" />

    <!-- Bank selector -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select Bank"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:textSize="14sp"
        android:layout_marginBottom="12dp" />

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="3"
        android:layout_marginBottom="32dp">

        <TextView android:id="@+id/tvBankHBL" android:layout_width="0dp" android:layout_height="44dp" android:layout_columnWeight="1" android:gravity="center" android:text="HBL" android:textSize="13sp" android:textColor="@color/purple_primary" android:background="@drawable/bg_menu_icon" android:layout_margin="4dp" />
        <TextView android:id="@+id/tvBankMeezan" android:layout_width="0dp" android:layout_height="44dp" android:layout_columnWeight="1" android:gravity="center" android:text="Meezan" android:textSize="13sp" android:textColor="@color/purple_primary" android:background="@drawable/bg_menu_icon" android:layout_margin="4dp" />
        <TextView android:id="@+id/tvBankUBL" android:layout_width="0dp" android:layout_height="44dp" android:layout_columnWeight="1" android:gravity="center" android:text="UBL" android:textSize="13sp" android:textColor="@color/purple_primary" android:background="@drawable/bg_menu_icon" android:layout_margin="4dp" />

        <TextView android:id="@+id/tvBankMCB" android:layout_width="0dp" android:layout_height="44dp" android:layout_columnWeight="1" android:gravity="center" android:text="MCB" android:textSize="13sp" android:textColor="@color/purple_primary" android:background="@drawable/bg_menu_icon" android:layout_margin="4dp" />
        <TextView android:id="@+id/tvBankWorldBank" android:layout_width="0dp" android:layout_height="44dp" android:layout_columnWeight="1" android:gravity="center" android:text="World Bank" android:textSize="12sp" android:textColor="@color/white" android:background="@drawable/bg_purple_button" android:layout_margin="4dp" />
        <TextView android:id="@+id/tvBankJazz" android:layout_width="0dp" android:layout_height="44dp" android:layout_columnWeight="1" android:gravity="center" android:text="JazzCash" android:textSize="12sp" android:textColor="@color/purple_primary" android:background="@drawable/bg_menu_icon" android:layout_margin="4dp" />
    </GridLayout>

    <!-- Confirm button -->
    <Button
        android:id="@+id/btnConfirmRecipient"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:text="Confirm Recipient"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="@drawable/bg_purple_button"
        android:stateListAnimator="@null" />

</LinearLayout>