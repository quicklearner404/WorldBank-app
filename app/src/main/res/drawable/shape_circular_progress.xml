<?xml version="1.0" encoding="utf-8"?>
<!-- res/drawable/shape_circular_progress.xml
     Used by pbMonthlyLimit in CardDetailActivity
     Shows a purple arc on a grey ring -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Background ring (grey track) -->
    <item android:id="@android:id/background">
        <shape android:shape="ring"
            android:innerRadiusRatio="2.8"
            android:thicknessRatio="8"
            android:useLevel="false">
            <solid android:color="@color/gray_divider" />
        </shape>
    </item>

    <!-- Progress arc (purple fill) -->
    <item android:id="@android:id/progress">
        <clip>
            <shape android:shape="ring"
                android:innerRadiusRatio="2.8"
                android:thicknessRatio="8"
                android:useLevel="true">
                <solid android:color="@color/purple_primary" />
            </shape>
        </clip>
    </item>

</layer-list>
